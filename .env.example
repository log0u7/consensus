# Configuration template. Copy to .env and fill in your keys.
# Layer per-environment overrides with ENV=<name> (see Makefile).

# ---------------------------------------------------------------------------
# Provider keys (set at least one)
# ---------------------------------------------------------------------------

# Zen - free, no credit card required. Get your key at https://opencode.ai
ZEN_API_KEY=REPLACE_WITH_YOUR_ZEN_KEY
ZEN_BASE_URL=https://opencode.ai/zen/v1

# OpenAI-compatible (also works for OpenRouter, Together, etc.)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (native Messages API + SSE streaming)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Local (Ollama, vLLM, llama.cpp - any OpenAI-compatible endpoint)
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_API_KEY=ollama

# ---------------------------------------------------------------------------
# Models per role  (format: "provider/model-id")
# ---------------------------------------------------------------------------
# Reasoner-class on Zen for lead/consensus, fast model for coder/panel.
# Use "zen/<model>" for Zen, "anthropic/<model>" for Anthropic native, etc.

CODER_MODEL=zen/deepseek-v3-0324
CONSENSUS_MODEL=zen/deepseek-r1-0528
LEAD_MODEL=zen/deepseek-r1-0528

# Review panel: comma-separated "name:provider/model[:max_tokens]"
# Unset = default Zen panel (deepseek-coder, qwen3-coder, mimo-vl)
# REVIEW_PANEL=deepseek:zen/deepseek-v3-0324, qwen:zen/qwen3-coder, mimo:zen/mimo-vl-7b-rl

# Per-role output budgets (lower = faster; too low truncates reasoning models)
CODER_MAX_TOKENS=8000
REVIEW_MAX_TOKENS=8000
CONSENSUS_MAX_TOKENS=8000
LEAD_MAX_TOKENS=16000
CHAT_MAX_TOKENS=4000

# ---------------------------------------------------------------------------
# Low-quota mode (toggled at runtime via /api/quota or the header pill)
# ---------------------------------------------------------------------------
# Coder + consensus drop to LOW_QUOTA_MODEL; Lead is never downgraded.
LOW_QUOTA_MODEL=zen/deepseek-v3-0324
LOW_QUOTA_PANEL_SIZE=2
# Auto-enable low-quota when a 429 exhausts its retries (1=on, 0=off).
AUTO_LOW_QUOTA=1

# ---------------------------------------------------------------------------
# Postgres / pgvector (optional RAG backend)
# ---------------------------------------------------------------------------
PG_USER=raguser
PG_PASSWORD=change_me_strong_password
PG_DB=ragdb
# RAG backend: "pgvector" (default, requires Postgres) or "sqlite"
RAG_BACKEND=pgvector
# SQLITE_VEC_PATH=rag.db   # used when RAG_BACKEND=sqlite

# ---------------------------------------------------------------------------
# Embeddings (RAG, optional)
# ---------------------------------------------------------------------------
EMBED_PROVIDER=zen
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
RAG_TOP_K=3
RAG_MIN_SCORE=0.2

# ---------------------------------------------------------------------------
# Web / API
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
SESSION_TTL_SECONDS=3600
SESSION_MAX=200
SESSION_BACKEND=memory
MAX_SPEC_CHARS=20000
MAX_MESSAGE_CHARS=8000
MAX_ARCHIVE_FILES=500
MAX_ARCHIVE_BYTES=52428800
ALLOWED_ORIGINS=http://localhost:8800
SSE_HEARTBEAT_SECONDS=10
MAX_CONCURRENT_RUNS=2

# ---------------------------------------------------------------------------
# Rate limits and per-provider RPM cap
# ---------------------------------------------------------------------------
RATE_LIMIT_RETRY_STATUSES=429,503
RATE_LIMIT_MAX_RETRIES=4
RATE_LIMIT_BASE_DELAY=2
RATE_LIMIT_MAX_DELAY=60
DEFAULT_RPM=60
# Per-provider override: RPM_ZEN=60, RPM_OPENAI=100, RPM_ANTHROPIC=50
